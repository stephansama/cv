{
	"name": "cv",
	"version": "1.0.0",
	"description": "curriculum vitae for @stephansama",
	"license": "MIT",
	"author": {
		"name": "Stephan Randle",
		"email": "stephanrandle@hotmail.com",
		"url": "https://stephansama.info/"
	},
	"type": "module",
	"scripts": {
		"build": "pnpm run --sequential \"/^build:.*/\"",
		"build:cv": "uv run rendercv render $npm_package_config_output_cv",
		"build:readme": "tsx ./scripts/readme-update.ts",
		"build:schema": "pnpm run --sequential \"/^build:schema-.*/\" ",
		"build:schema--gen": "tsx ./scripts/schema.ts",
		"build:schema--patch": "tsx ./scripts/schema-patch.ts",
		"build:schema-convert": "tsx ./scripts/schema-convert.ts",
		"build:www": "resume export $npm_package_config_output_html --theme=$npm_package_config_theme",
		"postbuild:www": "tsx ./scripts/add-og.ts",
		"dev": "pnpm run --parallel \"/^dev:.*/\"",
		"dev:add-og": "tsx watch ./scripts/add-og.ts",
		"dev:cv": "uv run rendercv render --watch $npm_package_config_output_cv",
		"dev:schema-convert": "tsx watch --include ./resume.json ./scripts/schema-convert.ts",
		"dev:www": "resume serve --theme=$npm_package_config_theme",
		"env:example": "tsx ./scripts/env.ts",
		"lint": "pnpm run --sequential \"/^lint:.*/\"",
		"lint:code": "eslint .",
		"lint:www": "resume validate",
		"release": "auto shipit",
		"spy:init": "uv run ./scripts/spy.py",
		"spy:sync": "dotenvx run -- tsx ./scripts/spy-sync.ts"
	},
	"config": {
		"output_cv": "rendercv.yaml",
		"output_html": "index.html",
		"theme": "catppuccin"
	},
	"dependencies": {
		"@auto-it/conventional-commits": "catalog:",
		"@auto-it/git-tag": "catalog:",
		"@auto-it/upload-assets": "catalog:",
		"auto": "catalog:",
		"cheerio": "catalog:",
		"jsonresume-theme-catppuccin": "catalog:",
		"ky": "catalog:",
		"resume-cli": "catalog:"
	},
	"devDependencies": {
		"@commitlint/cli": "catalog:",
		"@commitlint/config-conventional": "catalog:",
		"@commitlint/types": "catalog:",
		"@dotenvx/dotenvx": "catalog:",
		"@stephansama/ai-commit-msg": "catalog:",
		"@stephansama/auto-readme": "catalog:",
		"@stephansama/eslint-config": "catalog:",
		"@stephansama/github-env": "catalog:",
		"@stephansama/typed-env": "catalog:",
		"@stephansama/typed-nocodb-api": "catalog:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"eslint-plugin-zod": "catalog:",
		"fast-json-patch": "catalog:",
		"json-refs": "catalog:",
		"json-schema-to-zod": "catalog:",
		"lefthook": "catalog:",
		"nano-staged": "catalog:",
		"prettier-plugin-organize-imports": "catalog:",
		"prettier-plugin-packagejson": "catalog:",
		"tsx": "catalog:",
		"yaml": "catalog:",
		"zod": "catalog:",
		"zx": "catalog:"
	},
	"packageManager": "pnpm@11.1.2"
}
